# Transport mode: "stdio" (default) or "sse" (HTTP with Server-Sent Events)
MCP_TRANSPORT=sse

# SSE server settings (only used when MCP_TRANSPORT=sse)
MCP_HOST=0.0.0.0
MCP_PORT=8000

# API key for authentication (leave empty to disable auth)
MCP_API_KEY=

# Optional: Semantic Scholar API key for higher rate limits
SEMANTIC_SCHOLAR_API_KEY=
